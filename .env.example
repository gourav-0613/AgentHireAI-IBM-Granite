# ============================================================================
# AgentHire AI — Environment Variable Template
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# For Streamlit Community Cloud, add these as Secrets in the app dashboard.
# ============================================================================


# ----------------------------------------------------------------------------
# IBM Watsonx.ai — REQUIRED
# ----------------------------------------------------------------------------
# All three values are mandatory. The pipeline will refuse to start without them.

# Your IBM Cloud API key.
# Create one at: IBM Cloud → Manage → Access (IAM) → API keys → Create
IBM_WATSONX_API_KEY=a1dStR96cZogbXVvIDdS5jACj5lzE***************

# Your IBM Watson Studio project ID.
# Find it at: Watsonx.ai → Your Project → Manage → General → Project ID
IBM_WATSONX_PROJECT_ID=a1545074-53a6-4d81-a236-***********

# Watsonx.ai regional inference endpoint.
# Default (Dallas / us-south) — change only if your instance is in another region.
# Full list: https://cloud.ibm.com/apidocs/watsonx-ai#endpoint-url
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com


# ----------------------------------------------------------------------------
# Granite Model Identifiers — OPTIONAL (defaults shown)
# ----------------------------------------------------------------------------
# Override these only if the default Granite models are not available in your
# Watsonx.ai project or region.

# Model used for structured extraction tasks (Agents 1 & 2 — Resume Parser, JD Analyzer).
# Must be a text-generation model available on Watsonx.ai Foundation Models.
WATSONX_MODEL_EXTRACTION=ibm/granite-4-h-small

# Model used for generation and tailoring tasks (Agents 3–5 — Skill Gap, ATS, Tailor).
WATSONX_MODEL_GENERATION=ibm/granite-4-h-small


# ----------------------------------------------------------------------------
# Inference Hyperparameters — OPTIONAL (defaults shown)
# ----------------------------------------------------------------------------

# Maximum number of new tokens to generate per extraction call.
WATSONX_MAX_TOKENS_EXTRACTION=1500

# Maximum number of new tokens to generate per generation/tailoring call.
WATSONX_MAX_TOKENS_GENERATION=3000

# Sampling temperature for extraction agents (low = deterministic / factual).
WATSONX_TEMPERATURE_EXTRACTION=0.1

# Sampling temperature for generation agents (higher = more creative rewrites).
WATSONX_TEMPERATURE_GENERATION=0.7


# ----------------------------------------------------------------------------
# Application Limits — OPTIONAL (defaults shown)
# ----------------------------------------------------------------------------

# Maximum PDF upload size in megabytes. Uploads larger than this are rejected
# before any LLM call is made.
PDF_MAX_SIZE_MB=5


# ----------------------------------------------------------------------------
# Retry Policy — OPTIONAL (defaults shown)
# ----------------------------------------------------------------------------

# Number of retry attempts on transient Watsonx API errors (e.g. timeouts, HTTP 5xx).
WATSONX_MAX_RETRIES=3

# Base for exponential back-off between retries (seconds).
# Attempt 1 waits 1s, attempt 2 waits 2s, attempt 3 waits 4s, etc.
WATSONX_RETRY_BACKOFF_BASE=2.0
